# MineM local service
HOST=127.0.0.1
PORT=8790
AUTO_IMPORT_ON_START=0

# Leave empty to keep runtime data under the repository's ignored directories.
MINEM_DATA_DIR=
MINEM_IMPORT_ROOTS=

# Internal automation API is disabled by default.
MINEM_AGENT_INTERNAL_API=0
MINEM_AGENT_API_TOKEN=

# Upload and extraction limits, in bytes unless noted otherwise.
MAX_UPLOAD_BYTES=536870912
MAX_UPLOAD_REQUEST_BYTES=553648128
MAX_ZIP_FILES=5000
MAX_ZIP_MEMBER_BYTES=268435456
MAX_ZIP_TOTAL_BYTES=1073741824
MAX_ZIP_COMPRESSION_RATIO=120
